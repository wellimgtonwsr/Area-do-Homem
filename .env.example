# =====================================================
# ÁREA DO HOMEM — Variáveis de Ambiente
# =====================================================
# 1. Copie este arquivo:  copy .env.example .env
# 2. Preencha os valores abaixo
# 3. NUNCA envie o arquivo .env para o Git
# =====================================================

# ── Servidor ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Mercado Pago ──────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/pt/docs/getting-started/credentials
# Use TEST-xxx para testes · APP_USR-xxx para produção
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# ── URL pública do servidor (para o webhook do MP) ────
# Railway: https://area-do-homem.up.railway.app
# Vercel:  https://area-do-homem.vercel.app
# Deixe em branco para desenvolvimento local
APP_URL=
